PORT=8080
# Anything other than the literal value "development" is treated as
# production (fail-closed) — pprof stays disabled and API_KEY becomes
# required unless this is explicitly "development".
ENVIRONMENT=development

# Required whenever ENVIRONMENT is not "development". Guards every mutating
# route and worker trigger (POST/PATCH/DELETE) — see internal/api/middleware/auth.go.
# Generate one with: openssl rand -hex 32
API_KEY=

# Exact origins (comma-separated, no wildcards) allowed to call this API
# with credentials. Previously this hardcoded *.replit.dev/*.repl.co/*.replit.app
# wildcards, which let ANY other Repl app issue credentialed cross-origin
# requests — set this to the actual URL(s) the dashboard is served from.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Comma-separated proxy IPs/CIDRs to trust for X-Forwarded-For (used by the
# rate limiter and request logger's client-IP detection). Leave empty unless
# this server sits behind a reverse proxy/load balancer — trusting the wrong
# proxies (or all of them, Gin's old default) lets any client spoof its IP
# and bypass the rate limiter.
TRUSTED_PROXIES=

# Supabase PostgreSQL — direct connection (workers, long-lived)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Supabase Supavisor — transaction pooler (API handlers, short-lived)
# Uses simple query protocol (no prepared statements)
DATABASE_POOLER_URL=postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Used ONLY by the one-off migrate container (docker compose --profile migrate).
# Point at the Supabase DIRECT (non-pooler) URL with sslmode=require — the
# migrate tool needs the session protocol, not the transaction pooler.
DATABASE_MIGRATE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres?sslmode=require

# Connection pool sizes. Defaults (direct=5, pooler=12) are tuned to stay well
# under the Supabase free-tier connection budget — raise only if you know the
# instance's real limits.
# DB_MAX_CONNS=5
# DB_POOLER_MAX_CONNS=12

# Cross-process WebSocket fan-out via Postgres LISTEN/NOTIFY. Leave false for
# the single-VM deployment (cmd/server runs API + workers in one process);
# broadcasts are then delivered in-memory with no DB round-trip. Set true only
# if running cmd/worker as a separate process from the API server.
WS_MULTI_INSTANCE=false

# AI API Keys — OPTIONAL. The feed is fully functional without either: every
# article still gets classified, deduped, scored, and niche-tagged for free
# via keyword rules + the local embedding sidecar. These keys only enable the
# Enrich worker's paid pass (entity extraction + AI summaries on the small
# slice of articles the free pass flags — see AI_PENDING_MIN_FI_SCORE below)
# and the daily AI-written digest.
GROQ_API_KEY=gsk_xxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxx

# Local embedding sidecar (see ../embed-sidecar) — free, unlimited, no
# external API. Used for semantic dedup, semantic search, and niche tagging.
# docker-compose sets this to the service DNS name automatically; only
# change it if running the sidecar directly on the VM instead of in Docker.
EMBED_SIDECAR_URL=http://127.0.0.1:8900

# Worker intervals (optional — defaults shown)
RSS_INTERVAL_MINUTES=10
AI_INTERVAL_SECONDS=60
ENRICH_INTERVAL_SECONDS=150
MARKET_INTERVAL_MINUTES=5
IPO_INTERVAL_HOURS=6
ALERT_INTERVAL_MINUTES=2
DIGEST_HOUR_UTC=2

# AI processing gating (optional — defaults shown)
# AI_BATCH_SIZE: raw_items the free Process worker classifies/embeds/scores per cycle.
# ENRICH_BATCH_SIZE: ai_pending rows the paid Enrich worker spends budget on per cycle.
# VECTOR_DEDUP_THRESHOLD: cosine SIMILARITY — articles at or above this are the same story.
#   Calibrate against real near-duplicate/non-duplicate headline pairs before trusting it.
# AI_PENDING_MIN_FI_SCORE: FIScore a non-deal article needs to get a paid AI summary.
#   Deal-type articles (funding/ipo/mergers) are always flagged regardless of this value.
AI_BATCH_SIZE=30
ENRICH_BATCH_SIZE=30
VECTOR_DEDUP_THRESHOLD=0.88
AI_PENDING_MIN_FI_SCORE=70
