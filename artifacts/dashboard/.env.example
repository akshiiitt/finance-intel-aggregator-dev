# Frontend (Vite) build-time config. Copy to .env for local, or set these as
# Vercel project environment variables for production.

# The Go backend's public HTTPS origin. Leave UNSET for local dev — Vite's
# proxy forwards /api to http://localhost:8080. In production (Vercel) set this
# to the backend origin so the browser calls it directly:
#   VITE_API_BASE_URL=https://api.yourdomain.com
# The WebSocket URL (wss://) is derived from this automatically.
VITE_API_BASE_URL=

# Dev/preview server only — not needed for `vite build` on Vercel.
# PORT=5173
# BASE_PATH=/
